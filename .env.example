# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Circle Developer Console (for Circle Developer-Controlled Wallets)
CIRCLE_API_KEY=TEST_API_KEY:...
CIRCLE_WALLET_SET_ID=                        # populated by `npm run setup:wallets`

# x402 facilitator — public Coinbase facilitator works for the default testnet.
FACILITATOR_URL=https://x402.org/facilitator

# Settlement network for x402 payments. Arc testnet support is pending in x402;
# set to "base-sepolia" for the demo and switch to "arc-testnet" once x402 adds it.
X402_NETWORK=base-sepolia

# Router EOA — used by x402-fetch to sign USDC transfer authorizations.
# Generate via `npm run setup:wallets` or paste your own test key.
ROUTER_PRIVATE_KEY=0x
ROUTER_WALLET_ADDRESS=0x

# Agent wallet addresses — the payTo for each agent's x402 paywall.
AGENT_WALLET_WEB_RESEARCH=0x
AGENT_WALLET_DOC_ANALYSIS=0x
AGENT_WALLET_CODE_REVIEW=0x
AGENT_WALLET_SYNTHESIS=0x

# Ports (defaults shown)
ROUTER_PORT=3000
ROUTER_URL=http://localhost:3000
